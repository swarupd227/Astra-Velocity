# --- Database ---
POSTGRES_USER=astra
POSTGRES_PASSWORD=astra_local_dev
POSTGRES_DB=astra_velocity
# Used by the app when running on the host (dev mode):
DATABASE_URL=postgres://astra:astra_local_dev@localhost:5433/astra_velocity

# --- Redis ---
REDIS_URL=redis://localhost:6380

# --- Auth (generate with: openssl rand -base64 32) ---
AUTH_SECRET=change-me-generate-a-real-secret

# --- AI providers (leave empty to disable a provider) ---
ANTHROPIC_API_KEY=
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_ENDPOINT=
OLLAMA_BASE_URL=http://localhost:11434

# --- Feature flags ---
FEATURE_ENTRA_SSO=false
